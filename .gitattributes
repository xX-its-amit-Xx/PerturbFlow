# Normalize all text files to LF in the repository regardless of platform.
* text=auto eol=lf

# Explicit text files
*.py    text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.cfg   text eol=lf
*.txt   text eol=lf
Snakefile text eol=lf
Dockerfile text eol=lf

# Binary
*.h5    binary
*.h5ad  binary
*.parquet binary
*.png   binary
*.jpg   binary
*.ipynb text eol=lf
